# Local development and Docker Compose
# Copy this file to .env and replace sensitive values before starting the app.

# Application
APP_PORT=8082

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=go_user_system

# JWT
JWT_SECRET=replace_with_a_32_plus_chars_random_secret
JWT_EXPIRE_HOURS=24
